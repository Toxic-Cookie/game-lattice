{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/dialogue.schema.json",
  "title": "DialogueTreeDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "dialogue"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "dialogue"
    },
    "start": {
      "type": "string"
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "speaker": {
            "type": "string"
          },
          "line": {
            "type": "string"
          },
          "effects": {
            "type": "array",
            "items": {}
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "conditions": {
                  "type": "array",
                  "items": {}
                },
                "effects": {
                  "type": "array",
                  "items": {}
                },
                "next": {
                  "type": "string"
                }
              }
            }
          },
          "next": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}