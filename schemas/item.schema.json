{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/item.schema.json",
  "title": "ItemDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "item"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "item"
    },
    "name": {
      "type": "string"
    },
    "slot": {
      "type": "string"
    },
    "stackSize": {
      "type": "number"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "basePrice": {
      "type": "number"
    },
    "consumeOnUse": {
      "type": "boolean"
    },
    "useActions": {
      "type": "array",
      "items": {}
    },
    "equipEffects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {}
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}