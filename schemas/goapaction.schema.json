{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/goapaction.schema.json",
  "title": "GoapActionDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "goapaction"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "goapaction"
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": {}
    },
    "effects": {
      "type": "object",
      "additionalProperties": {}
    },
    "cost": {
      "type": "string"
    },
    "moveTo": {},
    "speed": {
      "type": "string"
    },
    "animation": {
      "type": "string"
    },
    "animationBlocking": {
      "type": "boolean"
    },
    "runEffects": {
      "type": "array",
      "items": {
        "type": "object",
        "x-lattice-union": "effect",
        "description": "A effect primitive payload; see the manifest for arg signatures.",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "DealDamage",
              "Heal",
              "ModifyStat",
              "ApplyStatus",
              "RemoveStatus",
              "GiveItem",
              "RemoveItem",
              "SetFlag",
              "PublishEvent",
              "SpawnEntity",
              "Teleport",
              "AreaDamage",
              "StartQuest"
            ]
          }
        },
        "required": [
          "type"
        ]
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}