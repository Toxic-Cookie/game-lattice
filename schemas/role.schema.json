{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/role.schema.json",
  "title": "RoleDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "role"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "role"
    },
    "slots": {
      "type": "number"
    },
    "condition": {
      "type": "string"
    },
    "ringRadius": {
      "type": "number"
    }
  },
  "required": [
    "id",
    "type"
  ]
}