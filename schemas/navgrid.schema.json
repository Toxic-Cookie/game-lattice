{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/navgrid.schema.json",
  "title": "NavGridDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "navgrid"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "navgrid"
    },
    "origin": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "cellSize": {
      "type": "number"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "legend": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "walkable": {
            "type": "boolean"
          },
          "cost": {
            "type": "number"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}