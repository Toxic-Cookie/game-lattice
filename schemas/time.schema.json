{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/time.schema.json",
  "title": "TimeDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "time"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "time"
    },
    "minutesPerGameDay": {
      "type": "number"
    },
    "daysPerSeason": {
      "type": "number"
    },
    "seasons": {
      "type": "array",
      "items": {
        "type": "string",
        "x-lattice-ref": "season"
      }
    },
    "startHour": {
      "type": "number"
    }
  },
  "required": [
    "id",
    "type"
  ]
}