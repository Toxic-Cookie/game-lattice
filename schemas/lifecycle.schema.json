{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/lifecycle.schema.json",
  "title": "LifecycleDef",
  "description": "JSON-defined initialization: which flags the world starts with and what gets spawned (plan/01 \u00A73). startingInventory joins the schema in M2.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "lifecycle"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "lifecycle"
    },
    "initialScene": {
      "type": "string"
    },
    "globalFlags": {
      "type": "object",
      "additionalProperties": {},
      "description": "Initial global blackboard flags (bool/number/string values)."
    },
    "spawns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entity": {
            "type": "string"
          },
          "count": {
            "type": "number"
          },
          "position": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}