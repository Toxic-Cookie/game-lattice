{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/collective.schema.json",
  "title": "CollectiveDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "collective"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "collective"
    },
    "budget": {
      "type": "number"
    },
    "sites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "position": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "group": {
            "type": "string",
            "x-lattice-ref": "group"
          },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "entity": {
                  "type": "string",
                  "x-lattice-ref": "entity"
                },
                "count": {
                  "type": "number"
                }
              }
            }
          },
          "spawnRadius": {
            "type": "number"
          }
        }
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}