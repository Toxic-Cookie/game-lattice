{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/quest.schema.json",
  "title": "QuestDef",
  "description": "Step-based quest (plan/03 \u00A74): each step has a completion condition and completion effects; optional event-driven counters feed the global blackboard (no entity polling).",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "quest"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "quest"
    },
    "name": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "count": {
            "type": "object",
            "properties": {
              "counter": {
                "type": "string"
              },
              "on": {
                "type": "string"
              },
              "where": {
                "type": "object",
                "additionalProperties": {}
              },
              "amount": {
                "type": "number"
              }
            }
          },
          "complete": {},
          "onComplete": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "onComplete": {
      "type": "array",
      "items": {},
      "description": "Effects run when the whole quest completes (target = player)."
    }
  },
  "required": [
    "id",
    "type"
  ]
}