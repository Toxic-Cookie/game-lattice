{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/schedule.schema.json",
  "title": "ScheduleDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "schedule"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "schedule"
    },
    "priority": {
      "type": "number"
    },
    "metaStates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "require": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interrupt": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "x-lattice-union": "task",
        "description": "A task primitive payload; see the manifest for arg signatures.",
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "ClearCondition",
              "FaceEntity",
              "MoveTo",
              "NextPatrolPoint",
              "PerformActivity",
              "PlayAnimation",
              "PublishEvent",
              "SelectNewSchedule",
              "SetCondition",
              "UseSmartObject",
              "Wait"
            ]
          }
        },
        "required": [
          "task"
        ]
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}