{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.dev/schemas/weather.schema.json",
  "title": "WeatherStateDef",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique def ID."
    },
    "type": {
      "const": "weather"
    },
    "description": {
      "type": "string",
      "description": "One line for humans and LLMs (surfaced by the manifest)."
    },
    "inherits": {
      "type": "string",
      "description": "Parent def ID (same kind); objects deep-merge, scalars override, arrays replace or take {\u0022$append\u0022/\u0022$remove\u0022} patches.",
      "x-lattice-ref": "weather"
    },
    "transitions": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "minHours": {
      "type": "number"
    },
    "maxHours": {
      "type": "number"
    },
    "flags": {
      "type": "object",
      "additionalProperties": {}
    },
    "onEnter": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string"
          },
          "effects": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "onExit": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string"
          },
          "effects": {
            "type": "array",
            "items": {}
          }
        }
      }
    }
  },
  "required": [
    "id",
    "type"
  ]
}